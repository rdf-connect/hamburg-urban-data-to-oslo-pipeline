map:rules_000 <http://rdfs.org/ns/void#exampleResource> map:map_begin_000, map:map_einde_000, map:map_geometry_000, map:map_kenmerk_000, map:map_meetpunt_000, map:map_meetreeks_000, map:map_observedProperty_000, map:map_sensor_000, map:map_tijdsinterval_000, map:map_verkeersmeting_000 ;
	rdf:type <http://rdfs.org/ns/void#Dataset> .

map:s_000 rml:reference "observation['@iot.selfLink']" ;
	rdf:type rr:SubjectMap .

map:s_001 rdf:type rr:SubjectMap ;
	rr:template "{observation['@iot.selfLink']}/kenmerk" .

map:s_002 rml:reference "thing['@iot.selfLink']" ;
	rdf:type rr:SubjectMap .

map:s_003 rdf:type rr:SubjectMap ;
	rr:template "{locations[0]['@iot.selfLink']}/geometry" .

map:s_004 rml:reference "sensor['@iot.selfLink']" ;
	rdf:type rr:SubjectMap .

map:s_005 rdf:type rr:SubjectMap ;
	rr:template "{observation['@iot.selfLink']}/phenomenonTime" .

map:s_006 rdf:type rr:SubjectMap ;
	rr:template "{observation['@iot.selfLink']}/phenomenonTime/begin" .

map:s_007 rdf:type rr:SubjectMap ;
	rr:template "{observation['@iot.selfLink']}/phenomenonTime/end" .

map:s_008 rml:reference "datastream['@iot.selfLink']" ;
	rdf:type rr:SubjectMap .

map:s_009 rml:reference "observedProperty['@iot.selfLink']" ;
	rdf:type rr:SubjectMap .

map:source_000 rml:iterator "$" ;
	rml:referenceFormulation ql:JSONPath ;
	rml:source "data.json" ;
	rdf:type rml:LogicalSource ;
	rdfs:label "source" .

