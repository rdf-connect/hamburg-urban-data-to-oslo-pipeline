map:source_000 rml:iterator "$" ;
	rml:referenceFormulation ql:JSONPath ;
	rml:source [ 
		a rdfc:Source;  
		rdfc:reader <http://example.org/source1> ;
	];
	rdf:type rml:LogicalSource ;
	rdfs:label "source" .

